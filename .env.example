# Docling credentials (choose one env: TST, PPD, PRD)
CBAI_API_KEY_TST="put-your-docling-tst-key-here"
CBAI_API_KEY_PPD="put-your-docling-ppd-key-here"
CBAI_API_KEY_PRD="put-your-docling-prd-key-here"
DOCLING_ENV=TST
DOCLING_URL=
DOCLING_API_KEY_VAR=
DOCLING_PDF_PATH="data/reseau ASF.pdf"
DOCLING_EXPORT_TYPE=markdown
DOCLING_CHUNKING_TYPE=hybrid
DOCLING_MAX_TOKEN_PER_CHUNK=7500
DOCLING_POLL_INTERVAL=5
DOCLING_POLL_ATTEMPTS=40
DOCLING_START_TIMEOUT=120
DOCLING_RESULT_TIMEOUT=60
DOCLING_PICTURE_MODEL=
DOCLING_PICTURE_PROMPT=Describe the image in French in three sentences. Be concise and accurate.

# LLM Sherpa credentials (mirrors Docling env vars by default)
LLMSHERPA_ENV=TST
LLMSHERPA_URL=
LLMSHERPA_API_KEY_VAR=
LLMSHERPA_ENDPOINT=parsing/
LLMSHERPA_QUERY=
LLMSHERPA_PDF_PATH="data/sample.pdf"
LLMSHERPA_PRESERVE_LAYOUT=true
LLMSHERPA_CHUNK_SIZE=800
LLMSHERPA_CHUNK_OVERLAP=100
LLMSHERPA_TIMEOUT=120

# Optional run labels for experiment tracking
RUN_LABEL=
RUN_NOTES=
